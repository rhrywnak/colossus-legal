use axum::{routing::get, Json, Router};
use hyper::http::{HeaderValue, Method};
use serde::Serialize;
use std::net::SocketAddr;
use tokio::net::TcpListener;
use tower_http::cors::{Any, CorsLayer};
use tracing_subscriber::EnvFilter;

use colossus_legal_backend::{
    api,
    config::AppConfig,
    neo4j::{check_neo4j, create_neo4j_graph},
    state::AppState,
};

async fn health_check() -> &'static str {
    "OK"
}

#[derive(Serialize)]
struct StatusResponse {
    app: &'static str,
    version: &'static str,
    status: &'static str,
}

async fn status() -> Json<StatusResponse> {
    Json(StatusResponse {
        app: "colossus-legal-backend",
        version: "0.1.0",
        status: "ok",
    })
}

#[tokio::main]
async fn main() {
    tracing_subscriber::fmt()
        .with_env_filter(EnvFilter::from_default_env())
        .init();

    // This loads .env automatically whenever you run cargo run.
    dotenvy::dotenv().ok();

    let config = AppConfig::from_env().unwrap_or_else(|err| {
        panic!("Failed to load configuration: {}", err);
    });

    let graph = create_neo4j_graph(&config)
        .await
        .unwrap_or_else(|err| panic!("Failed to connect to Neo4j at {}: {}", config.neo4j_uri, err));

    check_neo4j(&graph)
        .await
        .unwrap_or_else(|err| panic!("Neo4j connectivity check failed: {}", err));
    tracing::info!(
        "Connected to Neo4j at {} as {}",
        config.neo4j_uri,
        config.neo4j_user
    );

    let state = AppState { graph };

    let app = Router::new()
        .route("/health", get(health_check))
        .route("/api/status", get(status))
        // Dev-friendly CORS; tighten when deploying behind a proper gateway.
        .layer(
            CorsLayer::new()
                .allow_origin([
                    HeaderValue::from_static("http://localhost:5473"),
                    HeaderValue::from_static("http://localhost:3403"),
                ])
                .allow_methods([
                    Method::GET,
                    Method::POST,
                    Method::PUT,
                    Method::PATCH,
                    Method::DELETE,
                    Method::OPTIONS,
                ])
                .allow_headers(Any),
        )
        .merge(api::router())
        .with_state(state);

    // Read BACKEND_PORT (default: 3403 for colossus-legal)
    let port: u16 = std::env::var("BACKEND_PORT")
        .unwrap_or_else(|_| "3403".to_string())
        .parse()
        .expect("Invalid BACKEND_PORT");

    let addr = SocketAddr::from(([0, 0, 0, 0], port));
    tracing::info!("Starting colossus-legal backend on http://{}", addr);

    let listener = TcpListener::bind(addr).await.expect("Failed to bind port");

    axum::serve(listener, app)
        .await
        .expect("Server error");
}
